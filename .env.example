# Configuration de l'application OCR UVT

# Port de l'API (sera remplacé par $PORT sur Render)
API_PORT=8000

# Port du serveur web (pour développement local uniquement)
WEB_PORT=80

# Langue par défaut pour l'OCR
DEFAULT_LANGUAGE=eng+fra+ara

# Répertoire pour les fichiers temporaires
TEMP_UPLOADS_DIR=/app/temp_uploads

# Niveau de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# URL du frontend (pour CORS)
FRONTEND_URL=https://ocr-uvt-web.vercel.app

# URLs locales pour le développement (pour CORS)
LOCAL_FRONTEND_URLS=http://localhost:3000,http://localhost:8080

# Limite de taille des fichiers uploadés (en octets)
MAX_FILE_SIZE=10485760

# Nombre de workers uvicorn
UVICORN_WORKERS=4

# Timeout pour les requêtes OCR (en secondes)
OCR_TIMEOUT=60
